# `memory` = demo DB without installing Mongo (data lost on exit).
# For persistent local Mongo (via docker-compose.yml), use:
MONGODB_URI=mongodb://127.0.0.1:27017/shopkeeper
PORT=4000
# Comma-separated origins for browser CORS
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
# IANA timezone for node-cron (weekly Monday / monthly 1st at 09:00)
TZ=Asia/Kolkata
# First operator when users collection is empty (MongoDB)
AUTH_USERNAME=admin
AUTH_PASSWORD=admin123
# Set true to expose reset token/URL in API response (local dev only)
PASSWORD_RESET_DEBUG=false
# Used in server logs and reset links
FRONTEND_URL=http://localhost:3000
# Set true to block POST /api/auth/register
DISABLE_PUBLIC_SIGNUP=false
# Change this in production
AUTH_SECRET=replace-with-strong-random-secret
# Login token validity in seconds (default: 43200 = 12h)
AUTH_TOKEN_TTL_SECONDS=43200
